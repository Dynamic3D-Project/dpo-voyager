{
  "version": 2,
  "buildCommand": "npm run build-prod",
  "outputDirectory": "dist",
  "devCommand": "npm run watch",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/files/:path*",
      "destination": "/api/files/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "public": false,
  "regions": ["dub1"]
}
